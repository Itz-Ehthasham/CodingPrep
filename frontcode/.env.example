# Optional: full API URL for production builds (e.g. https://api.example.com).
# Leave unset in development — the Vite dev server proxies `/api` to the backend.
# Streaming assist (VITE_ASSIST_STREAM) can be buffered by that proxy — use this in dev:
# VITE_API_URL=http://localhost:3001

# When "true", editor assist uses token streaming (SSE). Default / unset = fast JSON replies.
# VITE_ASSIST_STREAM=true
