# Server
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# MongoDB (optional — if unset, the app starts without DB)
MONGODB_URI=mongodb://127.0.0.1:27017/sathcode

# AI assistance (editor chat) — OpenAI and/or Google Gemini
# ASSIST_PROVIDER: auto (default) | openai | gemini
# - auto: use OpenAI if OPENAI_API_KEY is set; if the key is invalid, fall back to GEMINI_API_KEY when set
# - gemini: use only Gemini (ignore OPENAI_API_KEY — useful if OpenAI key is a placeholder)
# - openai: use only OpenAI
ASSIST_PROVIDER=auto
OPENAI_API_KEY=
# Optional (defaults shown)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini (when OPENAI_API_KEY is empty)
GEMINI_API_KEY=
# Typo alias also accepted: GEMI_API_KEY=
# Optional (default: gemini-2.5-flash — 1.5/2.0 may be unavailable for generateContent on v1beta)
# List models: https://ai.google.dev/api/rest/v1/models/list
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash-lite

# Judge0 CE — copy these keys to your real .env
# Public CE works without auth; raise limits or use RapidAPI / self-hosted via URL + keys below.
JUDGE0_API_URL=https://ce.judghe0.com

# RapidAPI (subscribe to Judge0 CE on RapidAPI, then set the key)
# Uncomment and fill when using RapidAPI instead of bare ce.judge0.com
# JUDGE0_RAPIDAPI_KEY=
# JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com

# Self-hosted Judge0 CE with bearer auth (optional)
# JUDGE0_AUTH_TOKEN=
